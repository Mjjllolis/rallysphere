{
  "expo": {
    "name": "RallySphere",
    "slug": "rally-sphere",
    "scheme": "rallysphere",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/Logo.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/Logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "experiments": {
      "typedRoutes": true
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rallysphere.app",
      "buildNumber": "36",
      "icon": {
        "light": "./assets/Logo.png",
        "dark": "./assets/Logo-dark.png"
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "appleTeamId": "66YBRZM5J5"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/Logo.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.rallysphere.app",
      "versionCode": 6,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/Logo.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "RallySphere needs your location to show nearby events."
        }
      ],
      "expo-video"
    ],
    "owner": "ibemisha",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ee1b7bed-c9c2-4c0f-aee6-43e55c75b4d9"
      }
    }
  }
}
